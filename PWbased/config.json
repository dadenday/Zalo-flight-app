        "base_url": "https://www.flightradar24.com",
        "enabled": true,
        "selectors": {
            "cookie_accept": "button#onetrust-accept-btn-handler",
            "time_remaining": "span[data-testid='aircraft-panel__flight-time-remaining']"
        },
        "flight_list_selectors": {
            "search_box": "input#search-input",
            "airline_result_link_xpath": "//div[text()='Airlines']/following-sibling::div/a[contains(., '{airline_code}')]",
            "live_flights_link_xpath": "//a[contains(., 'Live {airline_code} flights')]",
            "data_table_body": "table#table-flighs-list > tbody",
            "data_table_rows": "table#table-flighs-list > tbody > tr",
            "flight_number_in_row": "td:nth-child(2) a",
            "aircraft_in_row": "td:nth-child(3)",
            "route_in_row": "td:nth-child(4)",
            "registration_in_row": "td:nth-child(5) a"
        },
        "patterns": {
            "arriving_in": "in\\s+((?:\\d{2}:\\d{2})|(?:\\d{1,2}h\\s)?\\d{1,2}m)",
            "landed_ago": "(\\d{2}:\\d{2})\\s+ago"
        }
    }]
